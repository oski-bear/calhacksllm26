# Copy this file to backend/.env and fill in local keys.
# backend/.env is gitignored; never commit real keys.

# Anthropic - get one at https://console.anthropic.com/ -> API Keys.
ANTHROPIC_API_KEY=

# Browserbase - get these from https://www.browserbase.com/ dashboard.
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Default works for local mock portal demos.
MOCK_PORTAL_BASE=http://localhost:5001/mock
